# Neon PostgreSQL Connection String
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Server Port
PORT=3001

# JWT Configuration
JWT_SECRET="trendhive-dev-secret-key-change-in-production"
JWT_EXPIRES_IN="7d"

# CORS Allowed Origin (set to your Netlify frontend URL in production)
CORS_ORIGIN="http://localhost:5173"
